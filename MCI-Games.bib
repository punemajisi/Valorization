@inproceedings{mckannaDividedAttentionComputer2009,
  title = {Divided Attention in Computer Game Play: {{Analysis}} Utilizing Unobtrusive Health Monitoring},
  shorttitle = {Divided Attention in Computer Game Play},
  booktitle = {2009 {{Annual International Conference}} of the {{IEEE Engineering}} in {{Medicine}} and {{Biology Society}}},
  author = {McKanna, J.A. and Jimison, H. and Pavel, M.},
  year = 2009,
  month = sep,
  pages = {6247--6250},
  issn = {1558-4615},
  doi = {10.1109/IEMBS.2009.5334662},
  urldate = {2025-07-21},
  abstract = {Divided attention is a vital cognitive ability used in important daily activities (e.g., driving), which tends to deteriorate with age. As with Alzheimer's and other neural degenerative conditions, treatment for divided attention problems is likely to be more effective the earlier it is detected. Thus, it is important that a method be found to detect changes in divided attention early on in the process, for both safety and health care reasons. We present here a new method for detecting divided attention unobtrusively, using performance on a computer game designed to force players to attend to different dimensions simultaneously in order to succeed. Should this model prove to predict scores on a standard test for divided attention, it could help to detect cognitive decline earlier in our increasingly computer-involved aging population, providing treatment efficacy benefits to those who will experience cognitive decline.},
  langid = {american},
  keywords = {Alzheimer's disease,Cognition,Computerized monitoring,Cultural differences,Human factors,Included,Patient monitoring,Senior citizens,Software performance,System testing,USA Councils},
  file = {/Users/u0150231/Library/CloudStorage/OneDrive-KULeuven/Papers/storage/LCEMJKJS/McKanna et al. - 2009 - Divided attention in computer game play Analysis utilizing unobtrusive health monitoring.pdf}
}

@article{mezrarMachineLearningSerious2022,
  title = {Machine Learning and {{Serious Game}} for the {{Early Diagnosis}} of {{Alzheimer}}'s {{Disease}}},
  author = {Mezrar, Samiha and Bendella, Fatima},
  year = 2022,
  month = aug,
  journal = {Simulation \& Gaming},
  volume = {53},
  number = {4},
  pages = {369--387},
  issn = {1046-8781, 1552-826X},
  doi = {10.1177/10468781221106850},
  abstract = {Background and Aim               Aging people can suffer from cognitive impairments with a range of symptoms, including memory, perception, and difficulty in solving problems called Alzheimer's disease (AD). The early detection of Mild Cognitive Impairment (MCI), which can develop AD, plays a major role in the management of patients to slow the decline in cognitive function, as treatments are effective at an early stage of the disease course. For this purpose, advanced computer technologies can provide a tool for the early detection of AD and prediction of disease progression. This article presents a serious game, including 16 mini-games that aimed at detecting AD or MCI in the mild stage. Based on gamification techniques and machine learning (ML), by overcoming the limitations of traditional tests. This gamified cognitive tool, entitled AlzCoGame, evaluates the main cognitive domains considered to be the most pertinent indicators in diagnosing cognitive impairments: working memory, episodic memory, executive functions, Visio-spatial orientation, concentration, and attention.                                         Results and Conclusion               Six predictive ML models have been implemented using the AlzCoGame dataset. We used the K-fold cross-validation and classification metrics to validate the model's performance. Based on the results of the pilot study, the best overall performance was obtained by the RF classifier with average Sensitivity = 0.89, Specificity = 0.93, Accuracy = 0.92, F1-Score = 0.91, and ROC = 0.91. We can deduce that including machine learning techniques and serious games could help improve certain aspects of the clinical diagnosis of cognitive impairment. Moreover, clinical trials are required to prove the impact of this gamified program on cognitive skills and evaluate usability measures.},
  langid = {american},
  keywords = {Included},
  annotation = {中科院分区升级版: 教育学4区\\
影响因子: 1.8\\
5年影响因子: 2.7},
  file = {/Users/u0150231/Library/CloudStorage/OneDrive-KULeuven/Papers/storage/3IG5MVXG/Mezrar and Bendella - 2022 - Machine learning and serious game for the early diagnosis of alzheimer’s disease.pdf}
}

